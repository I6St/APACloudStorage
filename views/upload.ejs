<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>上传文件 | APACloudStorage</title>
    <style>
        body {
            text-align: center;
        }
        input {
            margin: 10px;
            padding: 10px 20px;
        }
        input[type="submit"] {
            margin: 10px;
            padding: 10px 20px;
        }
    </style>
</head>
<body>
    <h1>上传文件</h1>
    <p><%= ip %>，欢迎你</p>
    <form action="/api/upload" method="post" enctype="multipart/form-data" id="upload-form">
        <label for="username">用户名:</label>
        <input type="text" id="username" name="username" required>
        <br>
        <label for="password">密码:</label>
        <input type="password" id="password" name="password" required>
        <br>
        <label for="file">选择文件:</label>
        <input type="file" id="file" name="file" required>
        <br>
        <p id="tip">文件大小限制: <%= maxSize %> GB, 不限制文件数量</p>
        <input type="submit" value="上传" id="upload-btn">
    </form>
    <hr><footer>&copy; APACloudStorage 2026. 保留所有权利。</footer>
</body>
<script>
    document.getElementById('upload-form').addEventListener('submit', function (e) {
        document.getElementById('tip').textContent = '上传中...';
        document.getElementById('upload-btn').disabled = true;
    });
</script>
</html>